{
    "name": "studip-opencast-plugin-courseware-build",
    "version": "1.0.0",
    "description": "The build for courseware opencast block compatible with SOP v3",
    "devDependencies": {},
    "directories": {
        "lib": "lib/BlockTypes"
    },
    "scripts": {
        "build:vue2": "npm --prefix ./vue2 install && npm --prefix ./vue2 run build",
        "build:vue3": "npm --prefix ./vue3 install && npm --prefix ./vue3 run build",
        "build": "npm run build:vue2 && npm run build:vue3",
        "dev:vue2": "npm --prefix ./vue2 run dev",
        "dev:vue3": "npm --prefix ./vue3 run dev",
        "dev": "npm run dev:vue2"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/elan-ev/studip-opencast-plugin.git"
    },
