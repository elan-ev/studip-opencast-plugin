{
  "name": "studip-opencast-plugin",
  "version": "3.31",
  "description": "Stud.IP plugin for Opencast",
  "author": "Till Glöggler <tgloeggl@uos.de>",
  "scripts": {
    "build": "./build_vendors.sh --no-dev && npm install && vite build && cd courseware; sh prebuild.sh",
    "build-dev": "./build_vendors.sh && npm install && vite build --mode development && cd courseware; sh prebuild.sh",
    "devcw": "cd courseware; sh watch.sh",
    "predev": "npm install",
    "dev": "./build_vendors.sh && vite build --watch --mode development",
    "prezip": "npm run build",
    "translate": "/bin/bash translate.sh && gettext-compile --output vueapp/i18n/translations.json locale/en/LC_MESSAGES/opencast.po",
    "zip": "mkdir -p build && zip -FSr build/Opencast-V$npm_package_version.zip app assets cronjobs install locale migrations lib vendor-studip5 vendor-studip6 templates static static_cw LICENSE INSTALL.md README.md bootstrap_migrations.php bootstrap.php OpencastV3.class.php plugin.manifest",
    "docs": "npx @redocly/cli build-docs docs/studip_opencast_routes.json --output docs/studip_opencast_routes.html",
    "tests": "php vendor-studip6/bin/codecept run --steps"
  },
  "devDependencies": {
    "@popperjs/core": "^2.11.8",
    "@redocly/cli": "^2.14.4",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/compiler-sfc": "^3.5.26",
    "@vueform/slider": "^2.1.10",
    "axios": "^1.13.2",
    "core-js": "^3.47.0",
    "date-fns": "^4.1.0",
    "easygettext": "^2.17.0",
    "focus-trap-vue": "^4.1.0",
    "install": "^0.13.0",
    "postcss": "^8.5.6",
    "regenerator-runtime": "^0.14.1",
    "sass": "^1.97.2",
    "sortablejs": "^1.15.6",
    "vite": "^5.4.10",
    "vue": "^3.5.26",
    "vue-axios": "^3.5.2",
    "vue-resizable": "^2.1.7",
    "vue-router": "^4.6.4",
    "vue3-gettext": "^2.4.0",
    "vue3-select": "^0.1.2",
    "vuedraggable": "^4.1.0",
    "vuex": "^4.1.0"
  },
  "browserslist": "> 0.25%, not dead, not IE 11",
  "bugs": {
    "url": "https://github.com/elan-ev/studip-opencast-plugin/issues"
  },
  "homepage": "https://github.com/elan-ev/studip-opencast-plugin#readme",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/elan-ev/studip-opencast-plugin.git"
  }
}
